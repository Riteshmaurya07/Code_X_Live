PORT=5000
NODE_ENV=production

# MongoDB Atlas (or any MongoDB cluster)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/codexlive?retryWrites=true&w=majority

# JWT — use a long random secret in production
JWT_SECRET=replace_with_a_long_random_secret_here

# Allowed frontend origins (comma-separated for multiple, e.g. preview + custom domain)
CLIENT_URL=https://your-app.vercel.app,https://codexlive.com

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# JDoodle API (for code execution)
JDOODLE_CLIENT_ID=your_jdoodle_client_id
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret

# Brevo SMTP (Nodemailer email)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_EMAIL=your-brevo-login-email@example.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_API_KEY=your-brevo-smtp-key
SMTP_FROM_EMAIL=noreply@codexlive.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste key with literal \n — do NOT collapse to a single line
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Cloudinary (for avatar/image uploads)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_APIKEY=your_cloudinary_api_key
CLOUDINARY_SECRETKEY=your_cloudinary_secret_key